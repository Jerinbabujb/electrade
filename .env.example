# ── ElecTrade Pro — Environment Configuration ─────────────
# For local testing: copy this file to .env
# The values below work out-of-the-box for local testing.
# Only change DB_PASSWORD and JWT_SECRET for production.

# Database password (can be anything for local testing)
DB_PASSWORD=ElecTrade2025

# JWT secret — must be at least 32 characters
JWT_SECRET=electrade-secret-key-change-this-in-production-2025

# Frontend URL (leave as-is for local testing)
FRONTEND_URL=http://localhost

# Email (optional — leave blank to disable email features)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
